//@version=5
indicator("chinaV3 — AMD Liquidity Framework", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=200)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

var g_swing   = "Swing Structure"
var g_fbos    = "FBOS / RBOS"
var g_poi     = "IDM POI"
var g_smt     = "SMT"

show_swings   = input.bool(true,  "Show Swing Highs/Lows",  group=g_swing)
show_struct   = input.bool(true,  "Show HH/HL/LH/LL labels",group=g_swing)
show_fbos     = input.bool(true,  "Show FBOS",              group=g_fbos)
show_rbos     = input.bool(true,  "Show RBOS",              group=g_fbos)
show_poi      = input.bool(true,  "Show IDM POI boxes",     group=g_poi)
poi_extend    = input.int(20,     "Extend POI bars",        group=g_poi, minval=1)
show_smt      = input.bool(true,  "Show SMT",               group=g_smt)

col_bull      = color.new(#22c55e, 0)
col_bear      = color.new(#ef4444, 0)
col_poi_bull  = color.new(#22c55e, 80)
col_poi_bear  = color.new(#ef4444, 80)
col_fbos      = color.new(#f59e0b, 0)
col_rbos      = color.new(#6c63ff, 0)
col_smt       = color.new(#f59e0b, 0)

// ═══════════════════════════════════════════════════════════════════════════════
// SWING HIGHS / LOWS  (3-candle classic)
// ═══════════════════════════════════════════════════════════════════════════════

swing_high = high[1] > high[2] and high[1] > high[0]
swing_low  = low[1]  < low[2]  and low[1]  < low[0]

// ── Structure labels (HH, HL, LH, LL) ────────────────────────────────────────
var float prev_sh = na
var float prev_sl = na

if swing_high
    struct_label = na(prev_sh) ? "" : high[1] > prev_sh ? "HH" : "LH"
    if show_swings
        label.new(bar_index[1], high[1], "▼",
                  style=label.style_label_down,
                  color=color.new(col_bear, 90),
                  textcolor=col_bear, size=size.tiny)
    if show_struct and not na(prev_sh)
        label.new(bar_index[1], high[1] + ta.atr(14) * 0.3, struct_label,
                  style=label.style_none,
                  textcolor=color.new(col_bear, 30), size=size.small)
    prev_sh := high[1]

if swing_low
    struct_label = na(prev_sl) ? "" : low[1] < prev_sl ? "LL" : "HL"
    if show_swings
        label.new(bar_index[1], low[1], "▲",
                  style=label.style_label_up,
                  color=color.new(col_bull, 90),
                  textcolor=col_bull, size=size.tiny)
    if show_struct and not na(prev_sl)
        label.new(bar_index[1], low[1] - ta.atr(14) * 0.3, struct_label,
                  style=label.style_none,
                  textcolor=color.new(col_bull, 30), size=size.small)
    prev_sl := low[1]

// ═══════════════════════════════════════════════════════════════════════════════
// FBOS — Failed Break of Structure
// (wick beyond last swing high/low, close back inside)
// ═══════════════════════════════════════════════════════════════════════════════

lookback = 20

var float ref_high_fbos = na
var float ref_low_fbos  = na
var int   ref_high_bar  = na
var int   ref_low_bar   = na

// Update reference levels from recent swing points
for i = 1 to lookback
    if high[i] > high[i+1] and high[i] > high[i-1]
        if na(ref_high_fbos) or high[i] > ref_high_fbos
            ref_high_fbos := high[i]
            ref_high_bar  := bar_index[i]
    if low[i] < low[i+1] and low[i] < low[i-1]
        if na(ref_low_fbos) or low[i] < ref_low_fbos
            ref_low_fbos := low[i]
            ref_low_bar  := bar_index[i]

// FBOS: wick through the level, close back inside
fbos_bearish = not na(ref_high_fbos) and high > ref_high_fbos and close < ref_high_fbos
fbos_bullish = not na(ref_low_fbos)  and low  < ref_low_fbos  and close > ref_low_fbos

if fbos_bearish and show_fbos
    label.new(bar_index, high + ta.atr(14) * 0.5, "FBOS",
              style=label.style_label_down,
              color=color.new(col_fbos, 10),
              textcolor=col_fbos, size=size.small)
    // Reset reference high after sweep
    ref_high_fbos := na

if fbos_bullish and show_fbos
    label.new(bar_index, low - ta.atr(14) * 0.5, "FBOS",
              style=label.style_label_up,
              color=color.new(col_fbos, 10),
              textcolor=col_fbos, size=size.small)
    ref_low_fbos := na

// ═══════════════════════════════════════════════════════════════════════════════
// RBOS — Real Break of Structure
// (genuine break after manipulation phase completes)
// ═══════════════════════════════════════════════════════════════════════════════

var bool pending_rbos_bull = false
var bool pending_rbos_bear = false
var float rbos_bull_level  = na
var float rbos_bear_level  = na

if fbos_bullish
    pending_rbos_bull := true
    // The RBOS level to break is the last swing high before the FBOS
    rbos_bull_level := ta.highest(high, lookback)

if fbos_bearish
    pending_rbos_bear := true
    rbos_bear_level := ta.lowest(low, lookback)

rbos_bullish = pending_rbos_bull and close > rbos_bull_level
rbos_bearish = pending_rbos_bear and close < rbos_bear_level

if rbos_bullish
    if show_rbos
        label.new(bar_index, low - ta.atr(14) * 0.8, "RBOS ↑",
                  style=label.style_label_up,
                  color=color.new(col_rbos, 10),
                  textcolor=col_rbos, size=size.normal)
    pending_rbos_bull := false

if rbos_bearish
    if show_rbos
        label.new(bar_index, high + ta.atr(14) * 0.8, "RBOS ↓",
                  style=label.style_label_down,
                  color=color.new(col_rbos, 10),
                  textcolor=col_rbos, size=size.normal)
    pending_rbos_bear := false

// ═══════════════════════════════════════════════════════════════════════════════
// IDM POI — Inducement Point of Interest
// Drawn as a box: 2-candle OB at the induced structure extreme
// Only valid after RBOS is confirmed
// ═══════════════════════════════════════════════════════════════════════════════

if rbos_bullish and show_poi
    // The IDM POI is the lowest 2-candle OB in the FBOS→RBOS window
    // Approximation: use the bar that formed the FBOS sweep low
    poi_high = math.max(low[1], low[2])
    poi_low  = math.min(low[1], low[2])
    poi_box  = box.new(bar_index - 2, poi_high, bar_index + poi_extend, poi_low,
                       border_color=col_bull, border_width=1,
                       bgcolor=col_poi_bull)
    label.new(bar_index - 1, poi_high, "IDM POI",
              style=label.style_label_up,
              color=color.new(col_bull, 80),
              textcolor=col_bull, size=size.small)

if rbos_bearish and show_poi
    poi_high = math.max(high[1], high[2])
    poi_low  = math.min(high[1], high[2])
    poi_box  = box.new(bar_index - 2, poi_high, bar_index + poi_extend, poi_low,
                       border_color=col_bear, border_width=1,
                       bgcolor=col_poi_bear)
    label.new(bar_index - 1, poi_low, "IDM POI",
              style=label.style_label_down,
              color=color.new(col_bear, 80),
              textcolor=col_bear, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// SMT — Smart Money Trap
// 2-candle OB at the manipulation extreme — NON-TRADABLE
// Delivers price to the IDM POI
// ═══════════════════════════════════════════════════════════════════════════════

prev_body = math.abs(close[1] - open[1])
curr_body = math.abs(close    - open)

// Bullish SMT: prior candle bearish, current engulfs bullishly
smt_bullish = close[1] < open[1] and close > open and
              close > open[1]   and curr_body >= prev_body * 0.75

// Bearish SMT: prior candle bullish, current engulfs bearishly
smt_bearish = close[1] > open[1] and close < open and
              close < open[1]   and curr_body >= prev_body * 0.75

if smt_bullish and show_smt
    smt_box = box.new(bar_index[1], math.max(high, high[1]),
                      bar_index + 3, math.min(low, low[1]),
                      border_color=color.new(col_smt, 40),
                      bgcolor=color.new(col_smt, 88))
    label.new(bar_index, math.min(low, low[1]) - ta.atr(14) * 0.3, "SMT",
              style=label.style_none,
              textcolor=color.new(col_smt, 20), size=size.tiny)

if smt_bearish and show_smt
    smt_box = box.new(bar_index[1], math.max(high, high[1]),
                      bar_index + 3, math.min(low, low[1]),
                      border_color=color.new(col_smt, 40),
                      bgcolor=color.new(col_smt, 88))
    label.new(bar_index, math.max(high, high[1]) + ta.atr(14) * 0.3, "SMT",
              style=label.style_none,
              textcolor=color.new(col_smt, 20), size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// DIV — Divergence (requires a second symbol on same chart or use alert)
// Shown as a background highlight when NQ/ES diverge on swing highs/lows
// ═══════════════════════════════════════════════════════════════════════════════

// To use DIV: add this indicator on NQ chart, then manually compare ES.
// A DIV alert fires when NQ forms a new swing extreme but ES does not confirm.

div_ref   = input.symbol("CME_MINI:ES1!", "Correlated symbol for DIV", group="DIV")
div_close = request.security(div_ref, timeframe.period, close)
div_high  = request.security(div_ref, timeframe.period, high)
div_low   = request.security(div_ref, timeframe.period, low)

div_sw_hi_nq = high[1] > high[2] and high[1] > high[0]
div_sw_hi_es = div_high[1] > div_high[2] and div_high[1] > div_high[0]
div_sw_lo_nq = low[1] < low[2] and low[1] < low[0]
div_sw_lo_es = div_low[1] < div_low[2] and div_low[1] < div_low[0]

var float prev_nq_sh = na
var float prev_es_sh = na
var float prev_nq_sl = na
var float prev_es_sl = na

div_bearish = false
div_bullish = false

if div_sw_hi_nq and div_sw_hi_es
    if not na(prev_nq_sh) and not na(prev_es_sh)
        div_bearish := high[1] > prev_nq_sh and not (div_high[1] > prev_es_sh)
    prev_nq_sh := high[1]
    prev_es_sh := div_high[1]

if div_sw_lo_nq and div_sw_lo_es
    if not na(prev_nq_sl) and not na(prev_es_sl)
        div_bullish := low[1] < prev_nq_sl and not (div_low[1] < prev_es_sl)
    prev_nq_sl := low[1]
    prev_es_sl := div_low[1]

bgcolor(div_bullish ? color.new(col_bull, 92) : na, title="DIV Bullish bg")
bgcolor(div_bearish ? color.new(col_bear, 92) : na, title="DIV Bearish bg")

if div_bullish
    label.new(bar_index[1], low[1] - ta.atr(14), "DIV ↑",
              style=label.style_label_up,
              color=color.new(col_bull, 70), textcolor=col_bull, size=size.small)

if div_bearish
    label.new(bar_index[1], high[1] + ta.atr(14), "DIV ↓",
              style=label.style_label_down,
              color=color.new(col_bear, 70), textcolor=col_bear, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════

alertcondition(fbos_bearish, "FBOS — Bearish sweep", "FBOS: Bearish liquidity sweep detected")
alertcondition(fbos_bullish, "FBOS — Bullish sweep", "FBOS: Bullish liquidity sweep detected")
alertcondition(rbos_bullish, "RBOS — Bullish confirmed", "RBOS: Manipulation complete — watch for IDM POI entry long")
alertcondition(rbos_bearish, "RBOS — Bearish confirmed", "RBOS: Manipulation complete — watch for IDM POI entry short")
alertcondition(div_bullish,  "DIV — Bullish divergence", "DIV: NQ lower low, ES does not confirm — potential long")
alertcondition(div_bearish,  "DIV — Bearish divergence", "DIV: NQ higher high, ES does not confirm — potential short")
